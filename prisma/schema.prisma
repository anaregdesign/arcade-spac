generator client {
  provider = "prisma-client"
  output   = "../app/lib/server/infrastructure/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum GameKey {
  MINESWEEPER
  SUDOKU
}

enum Difficulty {
  EASY
  NORMAL
  HARD
  EXPERT
}

enum PlayStatus {
  COMPLETED
  FAILED
  ABANDONED
  PENDING_SAVE
}

enum PeriodType {
  SEASON
  LIFETIME
}

enum VisibilityScope {
  TENANT_ONLY
  PRIVATE
}

model User {
  id               String             @id @default(cuid())
  entraObjectId    String             @unique
  displayName      String
  avatarUrl        String?
  joinedAt         DateTime           @default(now())
  onboardingSeenAt DateTime?
  visibilityScope  VisibilityScope    @default(TENANT_ONLY)
  profile          UserProfile?
  playResults      PlayResult[]
  leaderboardEntries LeaderboardEntry[]
  gameSummaries    UserGameSummary[]
  overallSummaries UserOverallSummary[]
}

model UserProfile {
  userId          String   @id
  tagline         String?
  favoriteGame    GameKey?
  streakDays      Int      @default(0)
  totalPlayCount  Int      @default(0)
  lastPlayedAt    DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id                String             @id @default(cuid())
  key               GameKey            @unique
  name              String
  shortDescription  String
  accentColor       String
  rulesSummary      String
  playResults       PlayResult[]
  leaderboardEntries LeaderboardEntry[]
  userGameSummaries UserGameSummary[]
}

model PlayResult {
  id                 String      @id @default(cuid())
  userId             String
  gameId             String
  difficulty         Difficulty
  startedAt          DateTime
  finishedAt         DateTime?
  status             PlayStatus
  cleared            Boolean
  leaderboardEligible Boolean
  primaryMetric      Int
  secondaryMetric    Int?
  hintCount          Int?
  mistakeCount       Int?
  competitivePoints  Int
  totalPointsDelta   Int         @default(0)
  rankDelta          Int?
  isPersonalBest     Boolean     @default(false)
  summaryText        String
  sharePath          String?
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  game               Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId, gameId, startedAt])
  @@index([gameId, status, competitivePoints])
}

model LeaderboardEntry {
  id            String     @id @default(cuid())
  periodType    PeriodType
  gameId        String?
  userId        String
  rank          Int
  points        Int
  deltaToLeader Int?
  deltaToNext   Int?
  capturedAt    DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  game          Game?      @relation(fields: [gameId], references: [id], onDelete: SetNull)

  @@unique([periodType, gameId, userId])
  @@index([periodType, gameId, rank])
}

model UserGameSummary {
  id                    String   @id @default(cuid())
  userId                String
  gameId                String
  currentRank           Int?
  bestCompetitivePoints Int      @default(0)
  personalBestMetric    Int?
  playCount             Int      @default(0)
  completedCount        Int      @default(0)
  lastPlayedAt          DateTime?
  recommendationText    String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game                  Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model UserOverallSummary {
  id                String     @id @default(cuid())
  userId            String
  periodType        PeriodType
  totalPoints       Int        @default(0)
  currentRank       Int?
  trendDelta        Int        @default(0)
  recentPlaySummary String?
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodType])
}
