generator client {
  provider = "prisma-client"
  output   = "../app/lib/server/infrastructure/generated/prisma"
}

datasource db {
  provider = "sqlserver"
}

model User {
  id               String             @id @default(cuid())
  entraTenantId    String             @db.NVarChar(64)
  entraObjectId    String             @db.NVarChar(64)
  displayName      String
  avatarUrl        String?
  joinedAt         DateTime           @default(now())
  onboardingSeenAt DateTime?
  visibilityScope  String             @default("TENANT_ONLY")
  profile          UserProfile?
  playResults      PlayResult[]
  feedbackLogs     UserFeedbackLog[]
  leaderboardEntries LeaderboardEntry[]
  gameSummaries    UserGameSummary[]
  overallSummaries UserOverallSummary[]
  favorites        UserFavorite[]

  @@unique([entraTenantId, entraObjectId])
}

model UserProfile {
  userId          String   @id
  tagline         String?
  themePreference String   @default("LIGHT")
  streakDays      Int      @default(0)
  totalPlayCount  Int      @default(0)
  lastPlayedAt    DateTime?
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Game {
  id                Int                @id @default(autoincrement())
  key               String             @unique
  name              String
  shortDescription  String
  accentColor       String
  rulesSummary      String
  playResults       PlayResult[]
  feedbackLogs      UserFeedbackLog[]
  leaderboardEntries LeaderboardEntry[]
  userGameSummaries UserGameSummary[]
  favorites         UserFavorite[]
}

model UserFavorite {
  userId    String
  gameId    Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game      Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@id([userId, gameId])
  @@index([gameId, createdAt(sort: Desc)])
}

model PlayResult {
  id                 String      @id @default(cuid())
  userId             String
  gameId             Int
  difficulty         String
  startedAt          DateTime
  finishedAt         DateTime?
  status             String
  cleared            Boolean
  leaderboardEligible Boolean
  primaryMetric      Int
  secondaryMetric    Int?
  hintCount          Int?
  mistakeCount       Int?
  competitivePoints  Int
  totalPointsDelta   Int         @default(0)
  rankDelta          Int?
  isPersonalBest     Boolean     @default(false)
  summaryText        String
  sharePath          String?
  shareToken         String?
  user               User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  game               Game        @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([userId, gameId, startedAt])
  @@index([gameId, status, competitivePoints])
  @@index([shareToken])
}

model LeaderboardEntry {
  id            String     @id @default(cuid())
  periodType    String
  gameId        Int?
  userId        String
  rank          Int
  points        Int
  deltaToLeader Int?
  deltaToNext   Int?
  capturedAt    DateTime   @default(now())
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  game          Game?      @relation(fields: [gameId], references: [id], onDelete: SetNull)

  @@unique([periodType, gameId, userId])
  @@index([periodType, gameId, rank])
}

model UserGameSummary {
  id                    String   @id @default(cuid())
  userId                String
  gameId                Int
  currentRank           Int?
  bestCompetitivePoints Int      @default(0)
  personalBestMetric    Int?
  playCount             Int      @default(0)
  completedCount        Int      @default(0)
  lastPlayedAt          DateTime?
  recommendationText    String?
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game                  Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@unique([userId, gameId])
}

model UserOverallSummary {
  id                String     @id @default(cuid())
  userId            String
  periodType        String
  totalPoints       Int        @default(0)
  currentRank       Int?
  trendDelta        Int        @default(0)
  recentPlaySummary String?
  updatedAt         DateTime   @updatedAt
  user              User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, periodType])
}

model UserFeedbackLog {
  id         String   @id @default(cuid())
  userId     String
  gameId     Int
  eventType  String
  reward     Int
  contextKey String   @default("global")
  loggedAt   DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  game       Game     @relation(fields: [gameId], references: [id], onDelete: Cascade)

  @@index([loggedAt(sort: Desc)])
  @@index([gameId, loggedAt(sort: Desc)])
  @@index([userId, loggedAt(sort: Desc)])
}
